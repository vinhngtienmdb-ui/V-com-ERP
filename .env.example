# ──────────────────────────────────────────────────────────────────
# VComm ERP — environment variables
# ──────────────────────────────────────────────────────────────────
# Quy ước:
#   * Biến KHÔNG có tiền tố VITE_ → chỉ server đọc (server.ts), không lộ ra browser.
#   * Biến VITE_* → được Vite nhúng vào bundle, KHÔNG được chứa secret.
# ──────────────────────────────────────────────────────────────────

# ── Server-only: Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=
# Model mặc định nếu không set: gemini-2.5-flash
GEMINI_MODEL=

# ── Server-only: Firebase Admin SDK (chọn 1 trong 2 cách) ───────
# Cách 1: JSON service account nhúng thẳng (dùng cho Cloud Run / container)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Cách 2: trỏ tới file service account (dev local)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Server-only: SePay ──────────────────────────────────────────
SEPAY_API_TOKEN=
SEPAY_WEBHOOK_SECRET=
SEPAY_CLIENT_ID=
SEPAY_CLIENT_SECRET=

# ── Client (Vite) — KHÔNG chứa secret ───────────────────────────
# Nếu khác origin (Cloud Run + Firebase Hosting), trỏ tới URL backend.
VITE_API_BASE_URL=

# Bank mặc định cho QR thanh toán iPOS (sẽ chuyển vào cấu hình store/tenant ở GĐ 1).
VITE_DEFAULT_BANK_ID=
VITE_DEFAULT_BANK_ACCOUNT=

# Tắt HMR khi chạy trong AI Studio
DISABLE_HMR=
