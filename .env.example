# =============================================================================
# V-com ERP — Environment Variables
# Copy file này thành .env và điền giá trị thật trước khi chạy
# =============================================================================

# -----------------------------------------------------------------------------
# Gemini AI
# Lấy tại: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key_here"

# -----------------------------------------------------------------------------
# Internal API Key — bí mật dùng chung giữa frontend và backend API routes
# Tạo bằng: openssl rand -hex 32
# QUAN TRỌNG: INTERNAL_API_KEY (server) và VITE_INTERNAL_API_KEY (client)
# phải có cùng giá trị
# -----------------------------------------------------------------------------
INTERNAL_API_KEY="your_random_secret_here"
VITE_INTERNAL_API_KEY="same_value_as_INTERNAL_API_KEY"

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# SePay — tích hợp thanh toán QR
# Đăng ký tại: https://sepay.vn
# -----------------------------------------------------------------------------
SEPAY_API_TOKEN=
SEPAY_WEBHOOK_SECRET=
SEPAY_CLIENT_ID=
SEPAY_CLIENT_SECRET=

# VITE_SEPAY_*: Hiển thị QR thanh toán ở client (chỉ cần bank + số TK, không cần secret)
# Để trống sẽ dùng giá trị mặc định: Vietcombank / 123456789
VITE_SEPAY_BANK_ID="970436"
VITE_SEPAY_ACCOUNT_NO="your_account_number_here"

# -----------------------------------------------------------------------------
# RBAC — Danh sách email admin (phân cách bằng dấu phẩy)
# Những email này được cấp quyền admin tự động khi đăng nhập lần đầu
# -----------------------------------------------------------------------------
VITE_ADMIN_EMAILS="admin@yourcompany.com,director@yourcompany.com"
