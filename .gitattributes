# Buộc tất cả file text dùng LF + UTF-8 — tránh tái diễn mojibake do editor trên Windows.
* text=auto eol=lf

*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.rules     text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
