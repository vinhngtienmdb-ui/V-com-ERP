rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Enterprise Staff / Admin logic ---
    // Note: In a real system, we'd check against a /staff/{uid} collection
    function isStaff() {
      return isEmailVerified() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function isAdmin() {
      return isEmailVerified() && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Collections ---

    // 1. Products
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());

      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
               data.sku is string && data.sku.size() > 0 &&
               data.price is number && data.price >= 0 &&
               data.stock is number && data.stock >= 0;
      }
    }

    // 2. Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.staffId == request.auth.uid || isAdmin());
      allow create: if isStaff() && isValidOrder(incoming());
      allow update: if (isAdmin() || (isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))) && isValidOrder(incoming());

      function isValidOrder(data) {
        return data.total is number && data.total >= 0 &&
               data.items is list && data.items.size() > 0 &&
               data.status in ['pending', 'completed', 'cancelled', 'returned'] &&
               data.paymentMethod in ['cash', 'qr', 'pos'];
      }
    }

    // 3. Customers (CRM)
    match /customers/{customerId} {
      allow read: if isStaff();
      allow create, update: if isStaff() && isValidCustomer(incoming());

      function isValidCustomer(data) {
        return data.name is string && data.name.size() > 0 &&
               data.phone is string && data.phone.size() >= 10;
      }
    }

    // 4. Staff Profiles
    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only admins can create/edit staff
    }

    // 5. Transactions
    match /transactions/{txId} {
      allow read: if isAdmin();
      allow create: if isStaff() && isValidTx(incoming());

      function isValidTx(data) {
        return data.type in ['income', 'expense'] &&
               data.amount is number && data.amount >= 0;
      }
    }
  }
}
