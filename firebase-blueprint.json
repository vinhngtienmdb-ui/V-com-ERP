{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Sản phẩm trong hệ thống PIM và iPOS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sku", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Đơn hàng từ các kênh bán hàng hoặc iPOS",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "discount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled", "returned"] },
        "paymentMethod": { "type": "string", "enum": ["cash", "qr", "pos"] },
        "staffId": { "type": "string" },
        "storeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "status", "paymentMethod"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Thông tin khách hàng và lòng trung thành",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "tier": { "type": "string", "enum": ["Standard", "Silver", "Gold", "Platinum"] },
        "points": { "type": "number" },
        "aiInsight": { "type": "string" },
        "lastPurchase": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Nhân viên vận hành hệ thống",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "branch": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "FinanceTransaction": {
      "title": "FinanceTransaction",
      "description": "Giao dịch tài chính (thu/chi)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "orderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "category"]
    },
    "IPosStaff": {
      "title": "IPosStaff",
      "description": "Nhân viên iPOS được phân quyền theo chi nhánh",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "employee"] },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "assignedStoreId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "role", "assignedStoreId"]
    },
    "IPosStore": {
      "title": "IPosStore",
      "description": "Cấu hình chi nhánh iPOS",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "managerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "config": {
          "type": "object",
          "properties": {
            "printReceiptAutomatically": { "type": "boolean" },
            "allowReturns": { "type": "boolean" },
            "requireShiftOpening": { "type": "boolean" }
          }
        }
      },
      "required": ["name", "managerId", "status"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Danh mục sản phẩm trung tâm"
    },
    "orders": {
      "schema": "Order",
      "description": "Bộ lưu trữ đơn hàng tập trung"
    },
    "customers": {
      "schema": "Customer",
      "description": "Dữ liệu khách hàng và CRM"
    },
    "staff": {
      "schema": "Staff",
      "description": "Hồ sơ nhân viên"
    },
    "transactions": {
      "schema": "FinanceTransaction",
      "description": "Nhật ký tài chính"
    },
    "ipos_staff": {
      "schema": "IPosStaff",
      "description": "Quản lý nhân sự iPOS theo chi nhánh"
    },
    "ipos_stores": {
      "schema": "IPosStore",
      "description": "Cấu hình vận hành chi nhánh iPOS"
    },
    "pos_products": {
      "schema": "Product",
      "description": "Bản sao sản phẩm tại chi nhánh"
    },
    "pos_customers": {
      "schema": "Customer",
      "description": "Bản sao khách hàng tại chi nhánh"
    },
    "campaigns": {
       "title": "Campaign",
       "type": "object",
       "properties": {
          "name": { "type": "string" },
          "discount": { "type": "number" },
          "status": { "type": "string" }
       }
    },
    "pos_campaigns": {
       "schema": "Campaign",
       "description": "Bản sao khuyến mãi tại chi nhánh"
    }
  }
}
