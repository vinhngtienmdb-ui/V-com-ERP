rules_version = '2';

// VComm ERP — production rules (v1, GĐ 0)
// Nguyên tắc:
//   * Mọi vai trò đọc từ custom claims trên Firebase ID token (request.auth.token.role).
//   * Không hardcode email. Tài khoản admin bootstrap qua CLI bằng Firebase Admin SDK.
//   * Default deny. Mỗi collection liệt kê quyền tường minh.
//   * Public read chỉ áp dụng cho collection `public_menu` (đã được denormalize, không có cost/margin).

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Primitives ──────────────────────────────────────────────────────────
    function isSignedIn()       { return request.auth != null; }
    function role()             { return isSignedIn() ? request.auth.token.role : ''; }
    function isStaff()          { return role() in ['staff', 'manager', 'director', 'admin']; }
    function isManager()        { return role() in ['manager', 'director', 'admin']; }
    function isAdmin()          { return role() == 'admin'; }
    function isValidId(id)      { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming()         { return request.resource.data; }
    function existing()         { return resource.data; }
    function changedKeys()      { return incoming().diff(existing()).affectedKeys(); }
    function hasOnlyChanged(ks) { return changedKeys().hasOnly(ks); }
    function isStoreMember(storeId) {
      // Staff chỉ thao tác được dữ liệu store mà họ thuộc về.
      return isSignedIn() && (
        isAdmin() ||
        (storeId is string && (request.auth.token.storeIds is list) && (storeId in request.auth.token.storeIds))
      );
    }

    // ── Default deny ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Public menu (eMenu) ─────────────────────────────────────────────────
    // CHỈ field cần thiết để render menu công khai (id, name, price, image, category, available).
    // KHÔNG có costPrice/hiddenCosts/margin — những field đó nằm ở /products.
    match /public_menu/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isManager();
    }

    // ── Products (internal) ─────────────────────────────────────────────────
    match /products/{productId} {
      allow get, list: if isStaff();
      allow create: if isManager() && isValidId(productId) && isValidProduct(incoming());
      // Staff thường chỉ được cập nhật stock.
      allow update: if isStaff() && isValidProduct(incoming()) && (
        (isManager() && hasOnlyChanged(['stock', 'price', 'costPrice', 'hiddenCosts', 'name', 'category', 'sku', 'image', 'status', 'updatedAt'])) ||
        (!isManager() && hasOnlyChanged(['stock', 'updatedAt']))
      );
      allow delete: if isAdmin();

      function isValidProduct(data) {
        return data.name is string && data.name.size() >= 2 && data.name.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               (!('costPrice' in data) || (data.costPrice is number && data.costPrice >= 0)) &&
               (!('stock' in data) || (data.stock is number && data.stock >= 0)) &&
               (!('sku' in data) || (data.sku is string && data.sku.size() > 0));
      }
    }

    // ── Orders ──────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow get, list: if isStaff();

      // Khách hàng eMenu tạo đơn không cần đăng nhập staff — đi qua app eMenu;
      // nhưng vẫn phải đúng schema và status = pending.
      allow create: if (
        (isStaff() && incoming().staffId == request.auth.uid) ||
        (!isSignedIn() && incoming().source == 'emenu' && incoming().status == 'pending')
      ) && isValidId(orderId) && isValidOrder(incoming()) && incoming().createdAt is timestamp;

      allow update: if isStaff() && isValidOrder(incoming()) &&
        incoming().staffId == existing().staffId &&
        incoming().createdAt == existing().createdAt &&
        hasOnlyChanged(['status', 'updatedAt', 'shippingLogs']) &&
        incoming().updatedAt is timestamp;

      allow delete: if isAdmin();

      function isValidOrder(data) {
        return data.total is number && data.total >= 0 &&
               data.items is list && data.items.size() > 0 && data.items.size() <= 200 &&
               data.status in ['pending', 'processing', 'shipped', 'delivered', 'completed', 'cancelled', 'returning', 'returned'] &&
               (!('paymentMethod' in data) || data.paymentMethod in ['cash', 'qr', 'pos', 'loyalty', 'loyalty_full', 'cod', 'bank_transfer', 'e_wallet', 'virtual_account', 'promo_qr']);
      }
    }

    // ── Customers ───────────────────────────────────────────────────────────
    match /customers/{customerId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isStaff() && isValidCustomer(incoming()) &&
        hasOnlyChanged(['name', 'phone', 'email', 'tier', 'points', 'aiInsight', 'lastPurchase', 'totalSpent', 'orderCount', 'channels', 'updatedAt']);
      allow delete: if isAdmin();

      function isValidCustomer(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.phone is string && data.phone.size() >= 9 && data.phone.size() <= 15 &&
               (!('email' in data) || data.email is string) &&
               (!('points' in data) || data.points is number) &&
               (!('status' in data) || data.status in ['active', 'inactive', 'locked']) &&
               (!('totalSpent' in data) || data.totalSpent is number) &&
               (!('orderCount' in data) || data.orderCount is number) &&
               (!('channels' in data) || data.channels is list);
      }
    }

    // ── Staff (profiles, không chứa role — role nằm trên custom claims) ─────
    match /staff/{staffId} {
      allow get: if isSignedIn() && (request.auth.uid == staffId || isManager());
      allow list: if isManager();
      // Self-update giới hạn field cá nhân; cấp role/admin phải qua CLI bootstrap.
      allow update: if isSignedIn() && request.auth.uid == staffId &&
        hasOnlyChanged(['name', 'phone', 'avatar', 'preferences', 'updatedAt']);
      // Admin tạo/sửa staff cho người khác; role thực vẫn được set qua custom claims.
      allow create, update, delete: if isAdmin();
    }

    // ── Stores (multi-tenant) ───────────────────────────────────────────────
    match /stores/{storeId} {
      allow get: if isStaff() && isStoreMember(storeId);
      allow list: if isManager();
      allow create, update, delete: if isAdmin();
    }

    // ── Shifts ──────────────────────────────────────────────────────────────
    match /shifts/{shiftId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isManager();
    }

    // ── Sellers (nhà bán hàng) ──────────────────────────────────────────────
    match /sellers/{sellerId} {
      allow get, list: if isStaff();
      // Manager+ tạo seller; status mặc định 'pending_docs'.
      allow create: if isManager() && isValidId(sellerId) && isValidSeller(incoming());
      // Update tách: KYC team (manager+) đổi status; admin set commission/suspended.
      allow update: if isStaff() && (
        // Staff thường chỉ chỉnh field profile non-sensitive
        (!isManager() && hasOnlyChanged(['ownerName', 'ownerEmail', 'ownerPhone', 'address', 'kycDocs', 'updatedAt'])) ||
        // Manager+ chỉnh KYC + commercial
        (isManager() && hasOnlyChanged([
          'name', 'ownerName', 'ownerEmail', 'ownerPhone', 'address', 'representative',
          'taxCode', 'identityCard', 'businessLicense', 'bankAccount', 'bankName',
          'kycDocs', 'commissionRate', 'status', 'verifiedAt',
          'totalProducts', 'totalGmv', 'rating', 'updatedAt',
        ])) ||
        // Admin có thể suspended/rejected
        (isAdmin() && hasOnlyChanged(['status', 'suspendedAt', 'suspendedReason', 'updatedAt']))
      );
      allow delete: if isAdmin();

      function isValidSeller(d) {
        return d.name is string && d.name.size() >= 2 && d.name.size() <= 200 &&
               d.entityType in ['individual', 'household', 'company'] &&
               d.status in ['pending_docs', 'pending_verification', 'verified', 'active', 'suspended', 'rejected', 'closed'] &&
               d.ownerName is string && d.ownerName.size() >= 2 &&
               d.ownerPhone is string && d.ownerPhone.size() >= 9 &&
               (!('commissionRate' in d) || (d.commissionRate is number && d.commissionRate >= 0 && d.commissionRate <= 1));
      }
    }

    // ── Wallets ─────────────────────────────────────────────────────────────
    match /wallets/{walletId} {
      // Seller xem ví của mình; staff xem tất cả; admin xem tất cả.
      allow get, list: if isStaff();
      // Tạo/update CHỈ qua Cloud Function (Admin SDK). Client không write trực
      // tiếp vào balance để tránh race condition và gian lận.
      allow create, update, delete: if false;
    }

    // ── Wallet transactions (sổ phụ, append-only) ───────────────────────────
    match /wallet_transactions/{txId} {
      allow get, list: if isStaff();
      // Append-only từ Cloud Function. Client thử ghi → deny.
      allow create, update, delete: if false;
    }

    // ── Inventory movements (append-only sổ kho) ────────────────────────────
    match /inventory_movements/{movId} {
      allow get, list: if isStaff();
      // Tạo từ client (qua transaction shipOrder/adjust). Validate schema chặt.
      allow create: if isStaff() && isValidMovement(incoming()) &&
        incoming().staffId == request.auth.uid &&
        incoming().createdAt is timestamp;
      // Append-only: không update/delete để giữ sổ kho minh bạch.
      allow update, delete: if false;

      function isValidMovement(d) {
        return d.productId is string && d.productId.size() > 0 &&
               d.quantity is number &&
               d.type in ['stock_in', 'stock_out', 'transfer', 'adjustment', 'return'] &&
               (!('refOrderId' in d) || d.refOrderId is string) &&
               (!('storeId' in d) || d.storeId == null || d.storeId is string);
      }
    }

    // ── Transactions (finance) ──────────────────────────────────────────────
    match /transactions/{txId} {
      allow get, list: if isManager();
      allow create: if isStaff() && incoming().createdAt is timestamp;
      // Không cho phép sửa/xóa — append-only. Sửa sai phải tạo bút toán đảo.
      allow update, delete: if false;
    }

    // ── SePay events (write-once từ Cloud Function/webhook) ─────────────────
    match /sepay_events/{eventId} {
      allow get, list: if isManager();
      // Chỉ admin SDK (server) mới được write — client deny hoàn toàn.
      allow create, update, delete: if false;
    }

    // ── Reconciliations (ghi từ reconcileSepayEvent function) ────────────────
    match /reconciliations/{id} {
      allow get, list: if isManager();
      allow create, update, delete: if false; // Chỉ Admin SDK
    }

    // ── Invoices (HĐ điện tử TT 78/2021) ────────────────────────────────────
    match /invoices/{invoiceId} {
      allow get, list: if isStaff();
      // Tạo qua Cloud Function (issueInvoice) để có số tuần tự an toàn.
      allow create, update, delete: if false;
    }

    // ── Seller tax reports (NĐ 117/2025) ────────────────────────────────────
    match /seller_tax_reports/{reportId} {
      allow get, list: if isManager();
      allow create, update, delete: if false; // Sinh tự động hàng tháng
    }

    // ── Audit log (immutable) ───────────────────────────────────────────────
    match /audit_logs/{id} {
      allow get, list: if isAdmin();
      // Chỉ admin SDK write từ Cloud Function onWrite — client deny.
      allow create, update, delete: if false;
    }

    // ── POS sync ────────────────────────────────────────────────────────────
    match /pos_sync_logs/{logId}    { allow read, write: if isStaff(); }
    match /pos_products/{id}        { allow read, write: if isStaff(); }
    match /pos_customers/{id}       { allow read, write: if isStaff(); }
    match /pos_campaigns/{id}       { allow read, write: if isManager(); }
    match /campaigns/{id}           { allow read, write: if isManager(); }

    // ── iPOS legacy collections ─────────────────────────────────────────────
    match /ipos_staff/{docId} {
      allow get: if isSignedIn();
      allow list: if isManager() || (isStaff() && resource.data.email == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }
    match /ipos_stores/{storeId} {
      allow get, list: if isStaff();
      allow write: if isAdmin();
    }

    // ── _internal (system meta) ─────────────────────────────────────────────
    match /_internal/{docId} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
