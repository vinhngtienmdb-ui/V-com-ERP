rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read: if isStaff();
      allow read, write: if false; // Deny all others
    }

    // --- Helper Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens never contain custom claims. Roles must be looked up.
    function getStaffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    
    function isStaff() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) ||
        request.auth.token.email == 'admin@v-erp.com' ||
        request.auth.token.email == 'vinh.ngtienmdb@gmail.com' ||
        // Check if user is in ipos_staff (requires a way to check without knowing docId, or specific rules per collection)
        true // Allow read for basic staff check if signed in, but refine per-collection
      );
    }
    
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && getStaffDoc().data.role == 'admin') ||
        request.auth.token.email == 'admin@v-erp.com' ||
        request.auth.token.email == 'vinh.ngtienmdb@gmail.com'
      );
    }

    // --- Helper for iPOS Store-based RBAC ---
    function getIPosStaff(storeId) {
       // Note: This is an expensive get() if called in a loop, but useful for single doc access
       // However, we don't know the docId of the staff record.
       // We'll rely on the user having a staff record in the store.
       return true; 
    }

    // --- Enterprise Collections ---
    
    // 0.1 Internal / System
    match /_internal/{docId} {
      allow read: if isSignedIn();
    }

    // iPOS Management
    match /ipos_staff/{docId} {
       allow get: if isSignedIn();
       allow list: if isSignedIn() && (
         isAdmin() || 
         resource.data.email == request.auth.token.email
       );
       // Allow querying by email for RBAC check
       allow list: if isSignedIn() && resource.data.email == request.auth.token.email;

       allow create, update, delete: if isSignedIn() && (
         isAdmin() ||
         // Simplified: admins/managers of the store can manage staff
         // In a real app, we'd lookup the role of the person making the request
         request.auth.token.email == 'vinh.ngtienmdb@gmail.com'
       );
    }

    match /ipos_stores/{storeId} {
       allow read: if isSignedIn();
       allow write: if isAdmin() || request.auth.token.email == 'vinh.ngtienmdb@gmail.com';
    }

    // 1. Products
    match /products/{productId} {
      allow read: if true; // Publicly readable for eMenu
      allow create: if isStaff();
      allow update: if isStaff() && isValidProduct(incoming()) && (
        isAdmin() ||
        (isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'updatedAt']))
      );
      allow delete: if isAdmin();

      function isValidProduct(data) {
        return data.name is string && data.name.size() >= 2 && data.name.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               // Optional fields for flexibility during seeding
               (data.stock == null || data.stock is number) &&
               (data.sku == null || (data.sku is string && data.sku.size() > 0));
      }
    }

    // 2. Orders
    match /orders/{orderId} {
      allow get: if isStaff();
      allow list: if isStaff();
      
      // Allow customers to create eMenu orders
      allow create: if (isStaff() || (incoming().source == 'emenu' && incoming().status == 'pending')) && 
                    isValidId(orderId) && isValidOrder(incoming()) && (
                      (isStaff() && incoming().staffId == request.auth.uid) || 
                      (incoming().source == 'emenu')
                    ) &&
                    incoming().createdAt is timestamp;
      
      allow update: if isStaff() && isValidOrder(incoming()) && (
        // Staff can complete their own orders, Admins can do anything
        (existing().staffId == request.auth.uid || isAdmin()) &&
        incoming().staffId == existing().staffId &&
        incoming().createdAt == existing().createdAt &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        incoming().updatedAt is timestamp
      );

      function isValidOrder(data) {
        return data.total is number && data.total >= 0 &&
               data.items is list && data.items.size() > 0 &&
               data.status in ['pending', 'processing', 'shipped', 'delivered', 'completed', 'cancelled', 'returning', 'returned'] &&
               (data.paymentMethod == null || data.paymentMethod in ['cash', 'qr', 'pos', 'loyalty', 'loyalty_full', 'cod', 'bank_transfer', 'e_wallet', 'virtual_account', 'promo_qr']);
      }
    }

    // 3. Customers
    match /customers/{customerId} {
      allow get: if isStaff();
      allow list: if isStaff();
      
      allow create: if isStaff() && isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isStaff() && isValidCustomer(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'tier', 'points', 'aiInsight', 'lastPurchase'])
      );

      function isValidCustomer(data) {
        return data.name is string && data.name.size() > 0 &&
               data.phone is string && data.phone.size() >= 10 &&
               (data.points == null || data.points is number) &&
               (data.email == null || data.email is string) &&
               (data.status == null || data.status is string) &&
               (data.totalSpent == null || data.totalSpent is number) &&
               (data.orderCount == null || data.orderCount is number) &&
               (data.channels == null || data.channels is list);
      }
    }

    // 4. Staff Profiles
    match /staff/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == 'admin@v-erp.com' && staffId == request.auth.uid);
    }
    
    // 4a. Shifts
    match /shifts/{shiftId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }

    // 5. Finance Transactions
    match /finance_transactions/{txId} {
      allow read: if isAdmin() || isStaff();
      allow create: if isStaff() && (
        incoming().createdAt is timestamp
      );
    }
    match /transactions/{txId} {
      allow read: if isAdmin() || isStaff();
      allow create: if isStaff() && (
        incoming().createdAt is timestamp
      );
    }

    // 6. Sync Logs
    match /pos_sync_logs/{logId} {
       allow read, write: if isStaff();
    }

    // 7. POS Sync Data
    match /pos_products/{id} { allow read, write: if isStaff(); }
    match /pos_customers/{id} { allow read, write: if isStaff(); }
    match /pos_campaigns/{id} { allow read, write: if isStaff(); }
    match /campaigns/{id} { allow read, write: if isStaff(); }

    // 8. Admin Audit & Tenant Audit Logs
    match /admin_audit_logs/{id} {
      allow create: if isValidAuditLog(incoming());
      allow read: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if isStaff();
      allow write: if isAdmin();

      match /audit_logs/{id} {
        allow create: if isValidAuditLog(incoming());
        allow read: if isAdmin();
      }
    }

    function isValidAuditLog(data) {
      return data.email is string && data.email.size() <= 150 &&
             data.action is string && data.action.size() <= 100 &&
             data.status in ['Success', 'Failed'] &&
             data.timestamp is string &&
             (data.userId == null || data.userId is string) &&
             (data.tenantId == null || data.tenantId is string);
    }
  }
}
