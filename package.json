{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs --format=cjs --external:vite",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "fix:encoding": "node scripts/fix-encoding.mjs",
    "fix:encoding:dry": "node scripts/fix-encoding.mjs --dry"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@sentry/react": "^10.53.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
    "react-router-dom": "^7.14.1",
    "react-virtuoso": "^4.18.6",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.19",
    "@types/react-grid-layout": "^1.3.6",
    "@types/xlsx": "^0.0.35",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.6"
  }
}
